## This prj config file enables almost all function that this Board (MC2) would have 
## ---------------------------------------------------------------------------------

## Configure memory
CONFIG_MAIN_STACK_SIZE=8192

#CONFIG_THREAD_STACK_INFO=y
#CONFIG_THREAD_ANALYZER=y
#CONFIG_THREAD_ANALYZER_AUTO=y

## Configure Power Management
#CONFIG_PM=y

## Configure USB peripheral
CONFIG_USB_DEVICE_STACK_NEXT=y
CONFIG_CDC_ACM_SERIAL_INITIALIZE_AT_BOOT=y

## Configure GPIO
CONFIG_GPIO=y

## Configure SPI
CONFIG_SPI=y
CONFIG_SPI_STM32=y
CONFIG_DMA=y
CONFIG_SPI_STM32_DMA=y

## Configure PWM
CONFIG_PWM=y
CONFIG_PWM_STM32=y
CONFIG_PINCTRL=y

## Activate serial console
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
#CONFIG_STDOUT_CONSOLE=y
#CONFIG_UART_LINE_CTRL=y

## Configure Logging
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_LOG_MODE_IMMEDIATE=y

## Enable SEGGER RTT logging
CONFIG_USE_SEGGER_RTT=y
CONFIG_LOG_BACKEND_RTT=y
CONFIG_LOG_BACKEND_RTT_MODE_BLOCK=y

## Config Events
CONFIG_EVENTS=y

## Configure Display
CONFIG_DISPLAY=y
CONFIG_FLASH=y
CONFIG_SPI=y

## Enable regulator framwork for LCD backlight
CONFIG_REGULATOR=y

## Configure LVGL
CONFIG_LVGL=y
CONFIG_LV_USE_LABEL=y
CONFIG_LV_USE_LOG=y

CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_FONT_MONTSERRAT_18=y
CONFIG_LV_Z_MEM_POOL_SIZE=32768 
##16384
## important to swap upper and lower bytes of the pixels
CONFIG_LV_COLOR_16_SWAP=y

CONFIG_LV_USE_BUTTON=y
CONFIG_LV_USE_ARC=y
CONFIG_LV_USE_IMAGE=y

## General for Ethernet
#CONFIG_POSIX_API=y

## Networking Config
#CONFIG_NETWORKING=n
#CONFIG_NET_IPV4=y
#CONFIG_NET_IPV6=y
#CONFIG_NET_SOCKETS=y
